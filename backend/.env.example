PORT=4000
NODE_ENV=development
# Local demo without Firebase: in-memory DB + demo auth header
MEMORY_STORE=1
SEED_DEMO=1
# Path to Firebase service account JSON (Firestore + Auth verify)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json
# Optional: comma-separated origins for CORS (default allows *)
CORS_ORIGIN=http://localhost:*
