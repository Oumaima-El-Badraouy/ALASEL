<?xml version="1.0" encoding="utf-8"?>
<!-- HTTP vers l’API locale (dev) : cleartext explicite pour éviter les échecs silencieux ExoPlayer/HttpClient. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
